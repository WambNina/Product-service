{
  "name": "product-service",
  "version": "1.0.0",
  "description": "Product Microservice for SaaS Marketplace with MySQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "node -e \"require('./src/config/initDatabase')()\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "docker:build": "docker build -t product-service .",
    "docker:run": "docker run -p 3002:3002 --env-file .env product-service"
  },
  "keywords": [
    "microservice",
    "product",
    "mysql",
    "saas",
    "marketplace"
  ],
  "author": "Your Name",
  "license": "PRIVATE",
  "dependencies": {
    "axios": "^1.13.6",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "nanoid": "^5.1.7",
    "node-cron": "^3.0.3",
    "sequelize": "^6.35.2",
    "sharp": "^0.33.1",
    "slugify": "^1.6.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
