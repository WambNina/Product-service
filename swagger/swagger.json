{
  "openapi": "3.0.0",
  "info": {
    "title": "Product Service API",
    "version": "1.0.0",
    "description": "Product microservice"
  },
  "paths": {
    "/api/v1/products": {
      "get": {
        "summary": "Get all products",
        "tags": ["Products"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "merchant_id",
            "in": "query",
            "schema": { "type": "string" }
          },
          { "name": "store_id", "in": "query", "schema": { "type": "string" } },
          {
            "name": "category_id",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "min_price",
            "in": "query",
            "schema": { "type": "number" },
            "description": "minimum Price"
          },
          {
            "name": "max_price",
            "in": "query",
            "schema": { "type": "number" },
            "description": "maximum Price"
          },
          {
            "name": "colors",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Comma-separated list of colors"
          },
          {
            "name": "sizes",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Comma-separated list of sizes"
          },
          { "name": "weight", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "summary": "Create product",
        "tags": ["Products"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["name", "price"],
                "properties": {
                  "name": { "type": "string", "example": "Television" },
                  "price": {
                    "type": "number",
                    "format": "float",
                    "example": 4000000.0
                  },
                  "merchant_id": { "type": "string", "example": "AB37" },
                  "store_id": { "type": "string", "example": "OM21" },
                  "category_id": { "type": "string" },
                  "category_name": { "type": "string" },
                  "description": { "type": "string" },
                  "quantity": { "type": "integer", "default": 0 },
                  "images": {
                    "type": "array",
                    "items": { "type": "string", "format": "binary" },
                    "maxItems": 5
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Données invalides" }
        }
      }
    },
    "/api/v1/products/search": {
      "get": {
        "summary": "Search products",
        "tags": ["Products", "Search"],
        "description": "Full-text search on products with relevance scoring",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Search query (name, description, tags)"
          },
          {
            "name": "category",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Category ID"
          },
          {
            "name": "min_price",
            "in": "query",
            "schema": { "type": "number" },
            "description": "Minimum price"
          },
          {
            "name": "max_price",
            "in": "query",
            "schema": { "type": "number" },
            "description": "Maximum price"
          },
          {
            "name": "status",
            "in": "query",
            "schema": { "type": "string", "enum": ["active", "draft", "archived"], "default": "active" }
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": { "type": "string", "enum": ["relevance", "price_asc", "price_desc", "newest", "name"], "default": "relevance" },
            "description": "Sort order"
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 },
            "description": "Page number"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 20 },
            "description": "Items per page"
          },
          {
            "name": "fields",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Comma-separated list of fields to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Product" }
                    },
                    "pagination": {
                      "type": "object",
                      "properties": {
                        "page": { "type": "integer" },
                        "limit": { "type": "integer" },
                        "total": { "type": "integer" },
                        "total_pages": { "type": "integer" }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "query": { "type": "string" },
                        "sort_by": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/products/filter": {
      "get": {
        "summary": "Filter products",
        "tags": ["Products", "Search"],
        "description": "Advanced filtering with multiple criteria",
        "parameters": [
          {
            "name": "categories",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Comma-separated category IDs"
          },
          {
            "name": "merchant_id",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "store_id",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "min_price",
            "in": "query",
            "schema": { "type": "number" }
          },
          {
            "name": "max_price",
            "in": "query",
            "schema": { "type": "number" }
          },
          {
            "name": "in_stock",
            "in": "query",
            "schema": { "type": "boolean" },
            "description": "Only show products with stock > 0"
          },
          {
            "name": "has_variants",
            "in": "query",
            "schema": { "type": "boolean" },
            "description": "Only show products with variants"
          },
          {
            "name": "tags",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Comma-separated tags"
          },
          {
            "name": "created_after",
            "in": "query",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "created_before",
            "in": "query",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": { "type": "string", "default": "created_at" }
          },
          {
            "name": "sort_dir",
            "in": "query",
            "schema": { "type": "string", "enum": ["ASC", "DESC"], "default": "DESC" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 20 }
          }
        ],
        "responses": {
          "200": {
            "description": "Filtered results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Product" }
                    },
                    "pagination": {
                      "type": "object",
                      "properties": {
                        "page": { "type": "integer" },
                        "limit": { "type": "integer" },
                        "total": { "type": "integer" },
                        "total_pages": { "type": "integer" }
                      }
                    },
                    "appliedFilters": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "type": { "type": "string" },
                          "value": {}
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/products/featured": {
      "get": {
        "summary": "Get featured products",
        "tags": ["Products", "Discovery"],
        "description": "Get featured/promoted products",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 8 },
            "description": "Number of products to return"
          },
          {
            "name": "category",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter by category ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Featured products list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Product" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/products/{id}": {
      "get": {
        "summary": "Get product by ID",
        "tags": ["Products"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": { "200": { "description": "Success" } }
      },
      "put": {
        "summary": "Update a product",
        "tags": ["Products"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "price": { "type": "number" },
                  "description": { "type": "string" },
                  "status": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "summary": "Delete a Product",
        "tags": ["Products"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID unique du produit",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Produit supprimé avec succès" },
          "404": { "description": "Produit non trouvé" }
        }
      }
    },
    "/api/v1/products/{id}/variants": {
      "get": {
        "summary": "Get product variants",
        "tags": ["Variants"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Product ID"
          }
        ],
        "responses": {
          "200": {
            "description": "List of variants",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/ProductVariant" }
                    }
                  }
                }
              }
            }
          },
          "404": { "description": "Product not found" }
        }
      },
      "post": {
        "summary": "Add variant to product",
        "tags": ["Variants"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Product ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ProductVariantInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Variant created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/ProductVariant" }
                  }
                }
              }
            }
          },
          "400": { "description": "Invalid data or SKU already exists" },
          "404": { "description": "Product not found" }
        }
      }
    },
    "/api/v1/products/{id}/variants/batch": {
      "post": {
        "tags": ["Variants"],
        "summary": "Upload product image and create multiple variants",
        "description": "Upload product image and configure color/size/weight variants in batch",
        "operationId": "uploadProductImageAndCreateVariants",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Product ID",
            "schema": {
              "type": "string",
              "example": "1a2ace3d-f1ba-4779-8aac-e336360faf12"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["image", "colors", "sizes"],
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary",
                    "description": "Product image file (jpg, png, webp)"
                  },
                  "colors": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": ["#000000", "#FF0000", "#00FF00", "#0000FF", "#FFFF00", "#FFFFFF", "#0000FF"]
                    },
                    "description": "Selected colors (checkbox array)"
                  },
                  "sizes": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": ["XS", "S", "M", "L", "XL", "XXL", "One Size"]
                    },
                    "description": "Selected sizes (checkbox array)"
                  },
                  "weight": {
                    "type": "number",
                    "default": 0,
                    "description": "Product weight in kg"
                  },
                  "price": {
                    "type": "decimal",
                    "default": 0,
                    "description": "set price"
                  },
                  "is_default": {
                    "type": "boolean",
                    "default": false,
                    "description": "Set as default product image"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Image uploaded and variants created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "message": { "type": "string" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "product_id": { "type": "string" },
                        "image_url": { "type": "string" },
                        "filename": { "type": "string" },
                        "variants_created": { "type": "number" },
                        "variants": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": { "type": "string" },
                              "sku": { "type": "string" },
                              "color": { "type": "string" },
                              "size": { "type": "string" },
                              "weight": { "type": "number" },
                              "price": { "type": "decimal"},
                              "is_default": { "type": "boolean" }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Validation error" },
          "404": { "description": "Product not found" }
        }
      }
    },
    "/api/v1/products/{variantId}": {
      "put": {
        "summary": "Update variant",
        "tags": ["Variants"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "variantId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Variant ID (UUID)"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ProductVariantInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Variant updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/ProductVariant" }
                  }
                }
              }
            }
          },
          "404": { "description": "Variant not found" }
        }
      },
      "delete": {
        "summary": "Delete variant",
        "tags": ["Variants"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "variantId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Variant ID (UUID)"
          }
        ],
        "responses": {
          "200": {
            "description": "Variant deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "description": "Cannot delete default variant" },
          "404": { "description": "Variant not found" }
        }
      }
    },
    "/api/v1/products/{id}/reviews": {
      "get": {
        "summary": "Get product reviews",
        "tags": ["Reviews", "Discovery"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Product ID"
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 10 }
          },
          {
            "name": "rating",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 5 },
            "description": "Filter by specific rating"
          }
        ],
        "responses": {
          "200": {
            "description": "Reviews list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Review" }
                    },
                    "pagination": {
                      "type": "object",
                      "properties": {
                        "page": { "type": "integer" },
                        "limit": { "type": "integer" },
                        "total": { "type": "integer" },
                        "total_pages": { "type": "integer" }
                      }
                    },
                    "summary": {
                      "type": "object",
                      "properties": {
                        "average_rating": { "type": "number" },
                        "total_reviews": { "type": "integer" },
                        "distribution": {
                          "type": "object",
                          "properties": {
                            "5": { "type": "integer" },
                            "4": { "type": "integer" },
                            "3": { "type": "integer" },
                            "2": { "type": "integer" },
                            "1": { "type": "integer" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/products/{id}/rating": {
      "get": {
        "summary": "Get product rating summary",
        "tags": ["Reviews", "Discovery"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Product ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Rating summary",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "product_id": { "type": "string" },
                        "average_rating": { "type": "number" },
                        "total_reviews": { "type": "integer" },
                        "breakdown": {
                          "type": "object",
                          "properties": {
                            "5": { "type": "integer" },
                            "4": { "type": "integer" },
                            "3": { "type": "integer" },
                            "2": { "type": "integer" },
                            "1": { "type": "integer" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": { "description": "Product not found" }
        }
      }
    },
    "/api/v1/products/{id}/related": {
      "get": {
        "summary": "Get related products",
        "tags": ["Discovery"],
        "description": "Get similar products based on category and tags",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Product ID"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 4 },
            "description": "Number of related products"
          }
        ],
        "responses": {
          "200": {
            "description": "Related products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Product" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/categories": {
      "get": {
        "summary": "Category List",
        "tags": ["Categories"],
        "responses": {
          "200": { "description": "Succès" }
        }
      },
      "post": {
        "summary": "Create a Category",
        "tags": ["Categories"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "example": "Électronique" },
                  "description": {
                    "type": "string",
                    "example": "Electronic devices and gadgets"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Category created" }
        }
      }
    },
    "/api/v1/categories/{id}": {
      "get": {
        "summary": "Detail of a category",
        "tags": ["Categories"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Succès" }
        }
      },
      "put": {
        "summary": "Modify a category",
        "tags": ["Categories"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" },
